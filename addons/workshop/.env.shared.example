# Variables de entorno compartidas del workshop.
#
# Copiar a `.env.shared` (gitignored) en el monorepo. Cada team puede tener
# además su propio `apps/<team>/.env.local` para vars privadas.
#
# Vars listadas acá deben coincidir con lo declarado en `workshop.yaml`:
# - `shared_infra.apis_external[].env_var`
# - `shared_infra.databases.url_env`
# - `shared_infra.secrets`

# --- Shell / general ---
NODE_ENV=development
SHELL_PORT=3000
LOG_LEVEL=info

# --- Database (workshop.yaml.shared_infra.databases.url_env) ---
DATABASE_URL=postgres://localhost:5432/workshop_dev

# --- APIs externas (workshop.yaml.shared_infra.apis_external[]) ---
# Reemplazar con las APIs declaradas en tu workshop.yaml.
OPENAI_API_KEY=sk-...

# --- Storage (workshop.yaml.shared_infra.storage[]) ---
# Modo vibe: dejar dummy hasta que un team realmente use storage.
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Mocks ---
# Set MOCKS=true para activar MSW handlers en el shell sin levantar backends.
MOCKS=false

# --- Observability ---
CORRELATION_HEADER=x-correlation-id
