# Variables de entorno compartidas del workshop (capa GLOBAL).
#
# Copiar a `.env.shared` (gitignored) en el monorepo. Vars listadas acá las
# necesitan TODOS los teams.
#
# Las vars team-specific viven en `apps/<team>/.env.local.example` →
# `apps/<team>/.env.local` (gitignored). El campo
# `workshop.yaml.shared_infra.apis_external[].access` decide qué archivo
# recibe cada var: `access: []` (vacío) o sin `access` → global; `access:
# [team-id, ...]` → team-specific.
#
# Ver `docs/workshop/secrets-strategy.md` para el modelo two-layer completo.

# --- Shell / general ---
NODE_ENV=development
SHELL_PORT=3000
LOG_LEVEL=info

# --- Database (workshop.yaml.shared_infra.databases.url_env) ---
DATABASE_URL=postgres://localhost:5432/workshop_dev

# --- Observability ---
CORRELATION_HEADER=x-correlation-id

# --- Mocks ---
# Set MOCKS=true para activar MSW handlers en el shell sin levantar backends.
MOCKS=false

# --- Vars team-specific ---
# Las vars de `workshop.yaml.shared_infra.apis_external[]` con `access:
# [team-id, ...]` declarado viven en `apps/<team>/.env.local.example`,
# no acá.
