# Variables de entorno team-specific.
#
# Copiar a `apps/<team>/.env.local` (gitignored).
#
# Mantener sincronizado con `workshop.yaml.shared_infra.apis_external[]`
# donde `access:` incluya este team-id.
#
# Ejemplos (descomentar/agregar según el workshop):
# OPENAI_API_KEY=sk-...
# STRIPE_API_KEY=sk_test_...
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
#
# Si el team no necesita ninguna var propia, dejar este archivo así con
# sólo este comentario (declarativo: "este team es 100% global").
