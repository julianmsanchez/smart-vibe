global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Backend metrics — Production
  - job_name: '{{PROJECT_NAME}}-backend-prod'
    scheme: https
    static_configs:
      - targets: ['{{PROD_HOST}}']    # ej: api.tuproyecto.com
        labels:
          env: 'production'
    metrics_path: /metrics
    scrape_interval: 10s
    scrape_timeout: 5s

  # Backend metrics — Development (local Docker)
  - job_name: '{{PROJECT_NAME}}-backend-dev'
    static_configs:
      - targets: ['host.docker.internal:{{PORT}}']
        labels:
          env: 'development'
    metrics_path: /metrics
    scrape_interval: 10s
    scrape_timeout: 5s

  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
