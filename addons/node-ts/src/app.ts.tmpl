/**
 * Entry point del backend.
 *
 * Patrón:
 *   1. Cargar y validar config (`validateConfig`).
 *   2. Crear logger raíz.
 *   3. Configurar Express con middlewares mínimos.
 *   4. Registrar rutas.
 *   5. Levantar el server.
 *
 * NOTA: separar `app` (la instancia configurada) de `server.ts` (que la
 * levanta en el puerto) ayuda para tests de integración con supertest.
 */

import express, { Request, Response, NextFunction } from 'express';
import { config, validateConfig } from './config/env';
import { createLogger, withLogContext } from './services/logger.service';

const logger = createLogger('app');

export function createApp(): express.Express {
  validateConfig();

  const app = express();

  // Middlewares base
  app.use(express.json({ limit: '1mb' }));
  app.use(express.urlencoded({ extended: true }));

  // Correlation ID por request: lee el header o genera uno y lo propaga
  // por AsyncLocalStorage. Todos los logs anidados llevarán el id.
  app.use((req: Request, res: Response, next: NextFunction) => {
    const correlationId =
      (req.headers['x-correlation-id'] as string) ||
      `req-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    res.setHeader('x-correlation-id', correlationId);
    withLogContext({ correlationId }, () => next());
  });

  // Healthcheck (siempre presente)
  app.get('/health', (_req, res) => {
    res.json({ status: 'ok', uptime: process.uptime() });
  });

  // TODO: registrar rutas de tu app acá.
  // app.use('/api/users', usersRouter);

  // Error handler de último recurso. Mantener al final.
  app.use((err: Error, _req: Request, res: Response, _next: NextFunction) => {
    logger.error('Unhandled error', { error: err.message, stack: err.stack });
    res.status(500).json({ error: 'Internal server error' });
  });

  return app;
}

// `server.ts` es el archivo que levanta el server real (no incluido acá).
