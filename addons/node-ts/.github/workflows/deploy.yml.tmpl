      #     # DATABASE_URL=$(aws ssm get-parameter --name /{{PROJECT_NAME}}/prod/database-url --with-decryption --query 'Parameter.Value' --output text)
      #     echo "TODO: implementar carga de secretos"

      # - name: Deploy Lambda
      #   run: |
      #     aws lambda update-function-code \
      #       --function-name $LAMBDA_FUNCTION_NAME \
      #       --zip-file fileb://lambda.zip \
      #       --publish

  deploy-fargate:
    if: false   # ⬅︎ activar si elegís Fargate (long-running)
    runs-on: ubuntu-latest
    needs: deploy-lambda

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      # - uses: aws-actions/amazon-ecr-login@v2
