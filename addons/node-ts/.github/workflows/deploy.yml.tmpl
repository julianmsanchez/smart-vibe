      # - run: docker push $ECR_REGISTRY/$ECR_REPOSITORY:$IMAGE_TAG
      # - run: aws ecs update-service --cluster $ECS_CLUSTER --service ... --force-new-deployment

  # Alternativas comunes para builders modo vibe:
  # - Vercel: usa su Git integration, no necesita workflow custom.
  # - Fly.io: `flyctl deploy` con FLY_API_TOKEN secret.
  # - Render: auto-deploy from main branch (config en dashboard).
