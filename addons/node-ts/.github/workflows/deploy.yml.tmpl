# Deployment workflow — DESACTIVADO por default en modo vibe
#
# Para activar:
#   1. Definir tu provider (AWS Lambda, Fargate, Vercel, Fly, Render, ...).
#   2. Quitar el `if: false` del job correspondiente.
#   3. Configurar secretos en Settings → Secrets and variables → Actions.
#   4. Documentar cualquier decisión de deployment como ADR en docs/decisions/.
#
# Activarlo es señal de que estás saliendo de modo vibe. Considerar pasar
# a graduating y operar con celeru-pro.

name: Deploy

on:
  push:
    branches: [main]

env:
  AWS_REGION: us-east-1
  # LAMBDA_FUNCTION_NAME: {{PROJECT_NAME}}-api
  # ECR_REPOSITORY: {{PROJECT_NAME}}
  # ECS_CLUSTER: {{PROJECT_NAME}}-cluster

jobs:
  deploy-lambda:
    if: false   # ⬅︎ activar cuando definas Lambda como target
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: '{{PACKAGE_MANAGER}}'

      - name: Install dependencies
        run: {{PACKAGE_MANAGER}} install --frozen-lockfile

      - name: Build TypeScript
        run: {{PACKAGE_MANAGER}} run build

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ env.AWS_REGION }}

      # - name: Package Lambda
      #   run: |
