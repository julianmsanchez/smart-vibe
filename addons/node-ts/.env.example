# .env.example — copiar a .env y completar valores reales
#
# Reglas:
#   - .env NUNCA se commitea (está en .gitignore).
#   - .env.example SÍ se commitea con placeholders/defaults seguros.
#   - Cada var declarada acá debe leerse desde src/config/env.ts.

# ---- App ----
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---- Database ----
# Reemplazar por tu provider (Postgres local, Neon, RDS, Supabase, ...).
DATABASE_URL=
DB_SCHEMA=public

# ---- Auth ----
# Token interno simple para endpoints administrativos.
INTERNAL_API_TOKEN=change-me-in-development

# Basic Auth para panel admin (opcional). Si vacío, /admin responde 503.
ADMIN_PANEL_USER=
ADMIN_PANEL_PASSWORD=

# ---- Servicios externos (ejemplos opcionales) ----
# Borrar lo que no uses.
LLM_API_KEY=
STORAGE_BUCKET=
